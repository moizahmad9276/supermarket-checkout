<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-seed-initial-data" author="moiz.ahmad">
        <!-- Items from the exercise pricing table -->
        <insert tableName="items">
            <column name="name" value="Apple"/>
            <column name="unit_price" value="30.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>
        <insert tableName="items">
            <column name="name" value="Banana"/>
            <column name="unit_price" value="50.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>
        <insert tableName="items">
            <column name="name" value="Peach"/>
            <column name="unit_price" value="60.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>
        <insert tableName="items">
            <column name="name" value="Kiwi"/>
            <column name="unit_price" value="20.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>

        <!-- Special offers: Apple 2 for 45, Banana 3 for 130 -->
        <insert tableName="special_offers">
            <column name="item_id" valueComputed="(SELECT id FROM items WHERE name = 'Apple')"/>
            <column name="quantity_required" value="2"/>
            <column name="offer_price" value="45.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>
        <insert tableName="special_offers">
            <column name="item_id" valueComputed="(SELECT id FROM items WHERE name = 'Banana')"/>
            <column name="quantity_required" value="3"/>
            <column name="offer_price" value="130.00"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>

        <rollback>
            <delete tableName="special_offers"/>
            <delete tableName="items"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
